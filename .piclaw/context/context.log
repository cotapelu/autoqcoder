## Concurrency

```rust
use tokio::sync::{Mutex, RwLock, broadcast, mpsc};
use std::sync::Arc;

let shared_data = Arc::new(Mutex::new(vec![]));
let mut handles = vec![];

for i in 0..10 {
    let data = shared_data.clone();
    let handle = tokio::spawn(async move {
        let mut guard = data.lock().await;
        guard.push(i);
    });
    handles.push(handle);
}

for h in handles { h.await.unwrap(); }
```

